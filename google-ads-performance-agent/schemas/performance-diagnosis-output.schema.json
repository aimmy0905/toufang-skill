{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openclaw.local/schemas/google-ads-performance-agent/performance-diagnosis-output.schema.json",
  "title": "PerformanceDiagnosisOutput",
  "type": "object",
  "additionalProperties": false,
  "required": ["diagnostics", "optimizationActions"],
  "properties": {
    "diagnostics": {
      "type": "object",
      "additionalProperties": false,
      "required": ["problemTypes", "signals", "hypotheses"],
      "properties": {
        "problemTypes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "signals": {
          "type": "array",
          "items": { "type": "string" }
        },
        "hypotheses": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["cause", "whyLikely", "howToVerify"],
            "properties": {
              "cause": { "type": "string" },
              "whyLikely": { "type": "string" },
              "howToVerify": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "optimizationActions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["priority", "action", "expectedImpact", "howToValidate"],
        "properties": {
          "priority": { "type": "string" },
          "action": { "type": "string" },
          "expectedImpact": { "type": "string" },
          "howToValidate": {
            "type": "array",
            "items": { "type": "string" }
          },
          "ownerHint": { "type": "string" }
        }
      }
    }
  }
}
