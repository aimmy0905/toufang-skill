{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openclaw.local/schemas/google-ads-campaign-agent/agent-output.schema.json",
  "title": "GoogleAdsCampaignAgentOutput",
  "type": "object",
  "additionalProperties": false,
  "required": ["goalSummary", "strategyPlan", "creativePack", "setupGuide", "optimizationActions"],
  "properties": {
    "goalSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["oneLine", "context", "priorities"],
      "properties": {
        "oneLine": { "type": "string", "minLength": 1 },
        "context": {
          "type": "object",
          "additionalProperties": false,
          "required": ["market", "timeRange", "budget"],
          "properties": {
            "market": { "type": "string", "minLength": 1 },
            "timeRange": { "type": "string", "minLength": 1 },
            "budget": { "type": "string", "minLength": 1 }
          }
        },
        "priorities": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "enum": ["impressions", "clicks", "conversions", "roas"] }
        },
        "assumptions": { "type": "array", "items": { "type": "string" } },
        "openQuestions": { "type": "array", "items": { "type": "string" } }
      }
    },
    "strategyPlan": {
      "type": "object",
      "additionalProperties": false,
      "required": ["recommendedMix", "budgetAllocation", "flightPlan", "keywordDirections", "audienceDirections", "notes"],
      "properties": {
        "recommendedMix": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["channel", "why", "when"],
            "properties": {
              "channel": { "type": "string", "enum": ["search", "pmax", "display", "youtube", "shopping", "remarketing"] },
              "why": { "type": "string", "minLength": 1 },
              "when": { "type": "string", "minLength": 1 }
            }
          }
        },
        "budgetAllocation": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["channel", "percentage", "ruleOfThumb"],
            "properties": {
              "channel": { "type": "string" },
              "percentage": { "type": "number", "minimum": 0, "maximum": 100 },
              "ruleOfThumb": { "type": "string" }
            }
          }
        },
        "flightPlan": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["phase", "dateRange", "goal", "actions"],
            "properties": {
              "phase": { "type": "string", "enum": ["warmup", "peak", "final_push"] },
              "dateRange": { "type": "string", "minLength": 1 },
              "goal": { "type": "string", "minLength": 1 },
              "actions": { "type": "array", "items": { "type": "string" } }
            }
          }
        },
        "keywordDirections": {
          "type": "object",
          "additionalProperties": false,
          "required": ["themes", "examples", "negativesToConsider"],
          "properties": {
            "themes": { "type": "array", "items": { "type": "string" } },
            "examples": { "type": "array", "items": { "type": "string" } },
            "negativesToConsider": { "type": "array", "items": { "type": "string" } }
          }
        },
        "audienceDirections": {
          "type": "object",
          "additionalProperties": false,
          "required": ["who", "signals", "remarketingWindows"],
          "properties": {
            "who": { "type": "array", "items": { "type": "string" } },
            "signals": { "type": "array", "items": { "type": "string" } },
            "remarketingWindows": { "type": "array", "items": { "type": "string" } }
          }
        },
        "notes": { "type": "array", "items": { "type": "string" } }
      }
    },
    "creativePack": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sellingPoints", "ctaOptions", "searchAds"],
      "properties": {
        "sellingPoints": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "ctaOptions": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "searchAds": {
          "type": "object",
          "additionalProperties": false,
          "required": ["headlines", "descriptions"],
          "properties": {
            "headlines": { "type": "array", "minItems": 5, "items": { "type": "string" } },
            "descriptions": { "type": "array", "minItems": 3, "items": { "type": "string" } }
          }
        },
        "assetDirections": { "type": "array", "items": { "type": "string" } },
        "landingPageSuggestions": { "type": "array", "items": { "type": "string" } }
      }
    },
    "setupGuide": {
      "type": "object",
      "additionalProperties": false,
      "required": ["campaignStructure", "namingRules", "biddingAndBudget", "trackingChecklist"],
      "properties": {
        "campaignStructure": { "type": "array", "items": { "type": "string" } },
        "namingRules": { "type": "array", "items": { "type": "string" } },
        "biddingAndBudget": { "type": "array", "items": { "type": "string" } },
        "trackingChecklist": { "type": "array", "items": { "type": "string" } }
      }
    },
    "diagnostics": {
      "type": "object",
      "additionalProperties": false,
      "required": ["problemType", "signals", "hypotheses"],
      "properties": {
        "problemType": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "enum": ["impression", "click", "conversion", "economics", "tracking"] }
        },
        "signals": { "type": "array", "items": { "type": "string" } },
        "hypotheses": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["cause", "whyLikely", "howToVerify"],
            "properties": {
              "cause": { "type": "string" },
              "whyLikely": { "type": "string" },
              "howToVerify": { "type": "array", "items": { "type": "string" } }
            }
          }
        }
      }
    },
    "optimizationActions": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["priority", "action", "expectedImpact", "howToValidate"],
        "properties": {
          "priority": { "type": "string", "enum": ["P0", "P1", "P2"] },
          "action": { "type": "string", "minLength": 1 },
          "expectedImpact": { "type": "string", "minLength": 1 },
          "howToValidate": { "type": "array", "items": { "type": "string" } },
          "ownerHint": { "type": "string", "enum": ["ads", "landing_page", "analytics", "creative"], "description": "Who should do it." }
        }
      }
    },
    "warnings": { "type": "array", "items": { "type": "string" } }
  }
}

