{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openclaw.local/schemas/google-ads-campaign-agent/planning-input.schema.json",
  "title": "PlanningInput",
  "type": "object",
  "additionalProperties": false,
  "required": ["business", "goal"],
  "properties": {
    "business": {
      "type": "object",
      "additionalProperties": false,
      "required": ["campaignName", "theme", "product", "market", "timeRange", "budget"],
      "properties": {
        "campaignName": { "type": "string", "minLength": 1 },
        "theme": { "type": "string", "minLength": 1, "description": "Activity theme, e.g. Mother's Day, Black Friday." },
        "product": {
          "type": "object",
          "additionalProperties": false,
          "required": ["name", "category", "priceRange"],
          "properties": {
            "name": { "type": "string", "minLength": 1 },
            "category": { "type": "string", "minLength": 1 },
            "priceRange": {
              "type": "object",
              "additionalProperties": false,
              "required": ["currency", "min", "max"],
              "properties": {
                "currency": { "type": "string", "minLength": 3, "maxLength": 3, "description": "ISO currency code, e.g. USD." },
                "min": { "type": "number", "minimum": 0 },
                "max": { "type": "number", "minimum": 0 }
              }
            }
          }
        },
        "market": {
          "type": "object",
          "additionalProperties": false,
          "required": ["country", "language"],
          "properties": {
            "country": { "type": "string", "minLength": 2, "description": "Target country, e.g. United States." },
            "language": { "type": "string", "minLength": 2, "description": "Primary language, e.g. en." }
          }
        },
        "timeRange": {
          "type": "object",
          "additionalProperties": false,
          "required": ["startDate", "endDate"],
          "properties": {
            "startDate": { "type": "string", "format": "date" },
            "endDate": { "type": "string", "format": "date" }
          }
        },
        "budget": {
          "type": "object",
          "additionalProperties": false,
          "required": ["currency", "total"],
          "properties": {
            "currency": { "type": "string", "minLength": 3, "maxLength": 3 },
            "total": { "type": "number", "minimum": 0 },
            "dailyCap": { "type": "number", "minimum": 0 }
          }
        },
        "valueProps": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "description": "Key selling points, e.g. 20% off, free shipping."
        },
        "landingPageUrl": {
          "type": "string",
          "format": "uri",
          "description": "Optional landing page URL."
        },
        "constraints": {
          "type": "object",
          "additionalProperties": true,
          "description": "Any additional constraints: shipping cutoff, stock limits, brand tone, compliance notes."
        }
      }
    },
    "goal": {
      "type": "object",
      "additionalProperties": false,
      "required": ["primaryObjective", "conversionAction"],
      "properties": {
        "primaryObjective": {
          "type": "string",
          "enum": ["brand_awareness", "traffic", "conversions", "remarketing"],
          "description": "Main objective category."
        },
        "conversionAction": {
          "type": "string",
          "minLength": 1,
          "description": "What counts as success, e.g. purchase, lead, signup."
        },
        "kpiTargets": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "targetCPA": { "type": "number", "minimum": 0 },
            "targetROAS": { "type": "number", "minimum": 0 },
            "targetConversions": { "type": "number", "minimum": 0 },
            "targetRevenue": { "type": "number", "minimum": 0 }
          }
        }
      }
    },
    "currentSetup": {
      "type": "object",
      "additionalProperties": false,
      "description": "Optional: if user already has some setup.",
      "properties": {
        "adTypes": {
          "type": "array",
          "items": { "type": "string", "enum": ["search", "pmax", "display", "youtube", "shopping", "remarketing"] }
        },
        "notes": { "type": "string" }
      }
    },
    "history": {
      "type": "object",
      "additionalProperties": false,
      "description": "Optional: previous learnings or historical results summary (not raw account export).",
      "properties": {
        "summary": { "type": "string" },
        "bestKeywords": { "type": "array", "items": { "type": "string" } },
        "topMarkets": { "type": "array", "items": { "type": "string" } }
      }
    }
  },
  "$defs": {
    "business": {
      "type": "object",
      "additionalProperties": false,
      "required": ["campaignName", "theme", "product", "market", "timeRange", "budget"],
      "properties": {
        "campaignName": { "type": "string", "minLength": 1 },
        "theme": { "type": "string", "minLength": 1, "description": "Activity theme, e.g. Mother's Day, Black Friday." },
        "product": {
          "type": "object",
          "additionalProperties": false,
          "required": ["name", "category", "priceRange"],
          "properties": {
            "name": { "type": "string", "minLength": 1 },
            "category": { "type": "string", "minLength": 1 },
            "priceRange": {
              "type": "object",
              "additionalProperties": false,
              "required": ["currency", "min", "max"],
              "properties": {
                "currency": { "type": "string", "minLength": 3, "maxLength": 3, "description": "ISO currency code, e.g. USD." },
                "min": { "type": "number", "minimum": 0 },
                "max": { "type": "number", "minimum": 0 }
              }
            }
          }
        },
        "market": {
          "type": "object",
          "additionalProperties": false,
          "required": ["country", "language"],
          "properties": {
            "country": { "type": "string", "minLength": 2, "description": "Target country, e.g. United States." },
            "language": { "type": "string", "minLength": 2, "description": "Primary language, e.g. en." }
          }
        },
        "timeRange": {
          "type": "object",
          "additionalProperties": false,
          "required": ["startDate", "endDate"],
          "properties": {
            "startDate": { "type": "string", "format": "date" },
            "endDate": { "type": "string", "format": "date" }
          }
        },
        "budget": {
          "type": "object",
          "additionalProperties": false,
          "required": ["currency", "total"],
          "properties": {
            "currency": { "type": "string", "minLength": 3, "maxLength": 3 },
            "total": { "type": "number", "minimum": 0 },
            "dailyCap": { "type": "number", "minimum": 0 }
          }
        },
        "valueProps": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "description": "Key selling points, e.g. 20% off, free shipping."
        },
        "landingPageUrl": {
          "type": "string",
          "format": "uri",
          "description": "Optional landing page URL."
        },
        "constraints": {
          "type": "object",
          "additionalProperties": true,
          "description": "Any additional constraints: shipping cutoff, stock limits, brand tone, compliance notes."
        }
      }
    },
    "goal": {
      "type": "object",
      "additionalProperties": false,
      "required": ["primaryObjective", "conversionAction"],
      "properties": {
        "primaryObjective": {
          "type": "string",
          "enum": ["brand_awareness", "traffic", "conversions", "remarketing"],
          "description": "Main objective category."
        },
        "conversionAction": {
          "type": "string",
          "minLength": 1,
          "description": "What counts as success, e.g. purchase, lead, signup."
        },
        "kpiTargets": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "targetCPA": { "type": "number", "minimum": 0 },
            "targetROAS": { "type": "number", "minimum": 0 },
            "targetConversions": { "type": "number", "minimum": 0 },
            "targetRevenue": { "type": "number", "minimum": 0 }
          }
        }
      }
    }
  }
}

