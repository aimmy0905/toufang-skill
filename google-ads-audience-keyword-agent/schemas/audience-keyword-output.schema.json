{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openclaw.local/schemas/google-ads-audience-keyword-agent/audience-keyword-output.schema.json",
  "title": "AudienceKeywordOutput",
  "type": "object",
  "additionalProperties": false,
  "required": ["audienceSegments", "intentMap", "keywordPlan"],
  "properties": {
    "audienceSegments": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["segment", "why", "priority"],
        "properties": {
          "segment": { "type": "string" },
          "why": { "type": "string" },
          "priority": { "type": "string" }
        }
      }
    },
    "intentMap": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["intentType", "examples"],
        "properties": {
          "intentType": { "type": "string" },
          "examples": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "keywordPlan": {
      "type": "object",
      "additionalProperties": false,
      "required": ["themes", "matchTypeGuidance", "negativeKeywords"],
      "properties": {
        "themes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "matchTypeGuidance": {
          "type": "array",
          "items": { "type": "string" }
        },
        "negativeKeywords": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}
