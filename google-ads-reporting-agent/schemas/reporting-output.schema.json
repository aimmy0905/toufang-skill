{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openclaw.local/schemas/google-ads-reporting-agent/reporting-output.schema.json",
  "title": "ReportingOutput",
  "type": "object",
  "additionalProperties": false,
  "required": ["summary", "findings", "nextActions", "learnings"],
  "properties": {
    "summary": {
      "type": "array",
      "items": { "type": "string" }
    },
    "findings": {
      "type": "array",
      "items": { "type": "string" }
    },
    "nextActions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "learnings": {
      "type": "array",
      "items": { "type": "string" }
    },
    "playbookNotes": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
