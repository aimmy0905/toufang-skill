{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openclaw.local/schemas/google-ads-data-ingestion-agent/data-ingestion-input.schema.json",
  "title": "DataIngestionInput",
  "type": "object",
  "additionalProperties": false,
  "required": ["sourceType", "timeWindow", "rawPayload"],
  "properties": {
    "sourceType": {
      "type": "string",
      "enum": ["google_ads", "ga4", "merchant_center", "manual_report", "blended"]
    },
    "timeWindow": {
      "type": "object",
      "additionalProperties": false,
      "required": ["startDate", "endDate"],
      "properties": {
        "startDate": { "type": "string" },
        "endDate": { "type": "string" }
      }
    },
    "rawPayload": {
      "type": "object",
      "additionalProperties": true
    },
    "mappingHints": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
